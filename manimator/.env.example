GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434


# OpenRouter configuration
OPENROUTER_MODEL=mistralai/mistral-small-2603
OPENROUTER_API_KEY=sk-or-v1-

# Set all agent models to use OpenRouter
INTENT_CLASSIFIER_MODEL=openrouter/mistralai/mistral-small-2603
# If intent calls fail with an API error about response_format, set to 1
INTENT_DISABLE_JSON_MODE=
# Same for scene decomposer / planner JSON object mode
SCENE_DECOMPOSER_DISABLE_JSON_MODE=
SCENE_PLANNER_DISABLE_JSON_MODE=
# Extra LiteLLM retries when assistant text is empty (default 6)
AMOEBA_LLM_EMPTY_RETRIES=
# Full intent re-tries on empty/JSON/schema errors, same model (default 1 → 2 attempts)
INTENT_TRANSIENT_RETRIES=
# Scene planner re-tries on LLM/JSON/schema errors per scene (default 1 → 2 attempts)
SCENE_PLANNER_TRANSIENT_RETRIES=
SCENE_PLANNER_MODEL=openrouter/mistralai/mistral-small-2603
SCENE_DECOMPOSER_MODEL=openrouter/mistralai/mistral-small-2603
CODE_REPAIR_MODEL=openrouter/mistralai/mistral-small-2603
CRITIC_MODEL=openrouter/mistralai/mistral-small-2603